# Runtime mode switch.
# PROD=false => local defaults (local JSON metadata + local audio storage)
# PROD=true  => cloud defaults (MongoDB metadata + S3 audio storage)
PROD=false

# NextAuth.js configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (required for login)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# AI provider: google (default) or openai
AI_PROVIDER=google

# Google API key (required when AI_PROVIDER=google)
# Get your API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Google model overrides
# GOOGLE_MODEL=gemini-1.5-flash
# GOOGLE_TRANSCRIPTION_MODEL=gemini-1.5-flash

# OpenAI API key (only required when AI_PROVIDER=openai)
# Get your API key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Prisma connection string
# Example: mongodb+srv://user:pass@cluster.mongodb.net/voxassist?retryWrites=true&w=majority
DATABASE_URL=

# Recording metadata persistence mode.
# Defaults to local in development and mongodb in production.
# RECORDINGS_PERSISTENCE_MODE=local

# Audio storage mode: local in development, s3 in production by default.
# Override when needed with local|s3.
# AUDIO_STORAGE_MODE=local

# Optional async job queue (BullMQ + Redis)
# ENABLE_JOB_QUEUE=true
# REDIS_URL=redis://localhost:6379

# S3 settings (required when AUDIO_STORAGE_MODE=s3 or NODE_ENV=production)
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_S3_ENDPOINT=
# AWS_S3_FORCE_PATH_STYLE=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional: Override the AI model used for report generation (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Override the transcription model (default: whisper-1)
# OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Default transcription source in new recording UI: browser|server
# Lowest-AI default is browser (uses Web Speech API first)
# NEXT_PUBLIC_DEFAULT_TRANSCRIPTION_MODE=browser































# Production mode
PROD=true

# MongoDB connection
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority"

# NextAuth (authentication)
NEXTAUTH_SECRET="your-very-long-random-secret"
NEXTAUTH_URL=https://your-production-domain.com

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI Provider (Groq via OpenAI compatibility)
AI_PROVIDER=openai
OPENAI_API_KEY=your-groq-api-key
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Optional: S3 storage (if using)
# AUDIO_STORAGE_MODE=s3
# AWS_S3_BUCKET=your-bucket
# AWS_S3_REGION=your-region
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Optional: Redis for job queue
# ENABLE_JOB_QUEUE=true
# REDIS_URL=redis://your-redis-host:6379

# Other Next.js/Prisma/Custom settings as needed