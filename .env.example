# OpenAI API Key (required for transcription and report generation)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override the AI model used for report generation (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: Override the transcription model (default: whisper-1)
# OPENAI_TRANSCRIPTION_MODEL=whisper-1
